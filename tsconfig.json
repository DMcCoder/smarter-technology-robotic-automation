{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "declaration": true,
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "types": ["node", "vitest/globals"],
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true
  },
  "include": ["cli.ts", "index.ts"],
  "exclude": ["dist", "node_modules", "test"]
}
